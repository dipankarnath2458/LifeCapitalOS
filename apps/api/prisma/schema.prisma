// Life Capital OS — data model.
// Monetary amounts are stored as BigInt minor units (paise/cents). PII fields are
// encrypted at the application layer (see common/crypto) before persistence.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADVISOR
  SUPPORT
  ANALYST
  ADMIN
  SUPERADMIN
}

enum PlanTier {
  free
  premium
  family_cfo
}

enum AccountType {
  bank
  investment
  retirement
  real_estate
  vehicle
  cash
  other_asset
  loan
  credit_card
}

enum AssetClass {
  equity
  debt
  gold
  real_estate
  cash
  crypto
  business
  other
}

enum TransactionType {
  income
  expense
  transfer
  adjustment
}

enum DebtType {
  home_loan
  personal_loan
  vehicle_loan
  education_loan
  business_loan
  credit_card
  other
}

enum DebtStatus {
  active
  closed
  written_off
  archived
}

enum DebtPaymentType {
  emi
  extra
  prepayment
  foreclosure
}

enum GoalType {
  retirement
  child_education
  child_marriage
  home_purchase
  emergency_fund
  travel
  custom
}

enum RiskTolerance {
  conservative
  moderate
  aggressive
}

enum SubscriptionStatus {
  active
  past_due
  canceled
  trialing
}

// ---- Phase 2 tenancy (MOD-1 / MOD-3) ----
// Firm-scoped staff role, resolved per Membership (not the global User.role).
enum FirmRole {
  OWNER
  ADVISOR
  ANALYST
  SUPPORT
}

// Client-scoped role within a household.
enum HouseholdRole {
  OWNER
  MEMBER
  VIEWER
}

// Legal owner of accounts within a household.
enum EntityType {
  individual
  huf
  trust
  llp
  company
  other
}

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  phone         String?   @unique
  passwordHash  String?
  role          Role      @default(USER)
  status        String    @default("active") // active | suspended | deleted
  emailVerified Boolean   @default(false)
  phoneVerified Boolean   @default(false)
  totpSecret    String? // encrypted
  activeFirmId  String? // last-used firm context for multi-firm users (MOD-1.5)
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  profile          Profile?
  subscription     Subscription?
  featureOverrides FeatureOverride[]
  accounts         Account[]
  transactions     Transaction[]
  debts            Debt[]
  goals            Goal[]
  familyMembers    FamilyMember[]
  netWorthSnaps    NetWorthSnapshot[]
  refreshTokens    RefreshToken[]
  otpCodes         OtpCode[]
  recommendations  Recommendation[]
  consents         Consent[]
  auditLogs        AuditLog[]        @relation("AuditActor")
  memberships      Membership[]

  @@index([status])
  @@index([role])
}

model Profile {
  id                  String        @id @default(cuid())
  userId              String        @unique
  user                User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName            String // encrypted
  dateOfBirth         DateTime?
  baseCurrency        String        @default("INR")
  annualIncomeMinor   BigInt?
  monthlyExpensesMinor BigInt?
  riskTolerance       RiskTolerance @default(moderate)
  dependents          Int           @default(0)
  taxResidency        String        @default("IN")
  // Protection tracking — powers the Insurance Gap and Early Warning signals.
  hasTermCover        Boolean       @default(false)
  hasHealthInsurance  Boolean       @default(false)
  termLifeCoverMinor  BigInt        @default(0)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
}

model FamilyMember {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String // encrypted
  relation    String
  dateOfBirth DateTime?
  isDependent Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([userId])
}

model Account {
  id           String      @id @default(cuid())
  // Retail owner. Nullable so an account can instead be owned by a household
  // (advisory tier). A row is either retail (userId set) or advisory (householdId
  // set); relaxing NOT NULL is backward-compatible — existing rows keep userId.
  userId       String?
  user         User?       @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  type         AccountType
  assetClass   AssetClass?
  currency     String      @default("INR")
  balanceMinor BigInt      @default(0)
  isLiability  Boolean     @default(false)
  // Account-aggregator linkage (nullable for manual accounts)
  aaProvider   String?
  aaAccountRef String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  // Phase 2 advisory scoping (M1b, promoted to relations in M2-2). Native currency
  // is kept per account; FX to the household base currency happens at aggregation.
  firmId       String?
  householdId  String?
  entityId     String?
  household    Household?  @relation(fields: [householdId], references: [id], onDelete: Cascade)
  entity       Entity?     @relation(fields: [entityId], references: [id], onDelete: SetNull)

  transactions Transaction[]

  @@index([userId])
  @@index([firmId])
  @@index([householdId])
  @@index([entityId])
}

model Transaction {
  id         String          @id @default(cuid())
  // Retail owner. Nullable so a transaction can instead be owned by a household
  // (advisory tier). A row is either retail (userId set) or advisory (householdId
  // set); relaxing NOT NULL is backward-compatible — existing rows keep userId.
  userId     String?
  user       User?           @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId  String
  account    Account         @relation(fields: [accountId], references: [id], onDelete: Cascade)
  type       TransactionType
  amountMinor BigInt
  // Native ISO currency of the transaction; FX to the household base happens at
  // aggregation (ADR-003) — no converted amount is stored.
  currency   String          @default("INR")
  // Household base currency at entry time (denormalized reference only).
  baseCurrency String?
  category   String
  note       String?
  tags       String[]        @default([])
  // Lifecycle: cleared | pending | void (void excluded from summaries).
  status     String          @default("cleared")
  occurredAt DateTime
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @default(now()) @updatedAt
  // Provenance of the acting users (advisory tier).
  createdById String?
  updatedById String?
  // Phase 2 advisory scoping — nullable, additive (M1b; householdId promoted to a
  // relation in M2-4).
  firmId      String?
  householdId String?
  household   Household?      @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@index([userId, occurredAt])
  @@index([accountId])
  @@index([firmId])
  @@index([householdId])
  @@index([householdId, occurredAt])
}

// Monthly household budget (M2-4). One per (householdId, periodMonth 'YYYY-MM').
// The overall cap plus per-category envelopes (BudgetLine); actuals are computed
// live from the transaction ledger, never stored here.
model Budget {
  id              String       @id @default(cuid())
  householdId     String
  firmId          String
  // Budget period as 'YYYY-MM' (a household budgets one month at a time).
  periodMonth     String
  // Base currency the envelopes are expressed in.
  currency        String       @default("INR")
  // Optional overall monthly cap (minor units); null = no overall cap.
  totalAmountMinor BigInt?
  createdById     String?
  updatedById     String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @default(now()) @updatedAt

  household Household    @relation(fields: [householdId], references: [id], onDelete: Cascade)
  lines     BudgetLine[]

  @@unique([householdId, periodMonth])
  @@index([householdId])
  @@index([firmId])
}

// A per-category envelope within a monthly budget (M2-4).
model BudgetLine {
  id          String @id @default(cuid())
  budgetId    String
  category    String
  amountMinor BigInt

  budget Budget @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  @@unique([budgetId, category])
  @@index([budgetId])
}

model Debt {
  id                   String   @id @default(cuid())
  // Retail owner. Nullable so a debt can instead be owned by a household (advisory
  // tier). A row is either retail (userId set) or advisory (householdId set);
  // relaxing NOT NULL is backward-compatible — existing rows keep userId.
  userId               String?
  user                 User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  name                 String
  type                 DebtType
  // Secured (home/vehicle/loan-against-asset) vs unsecured (personal/education/card).
  secured              Boolean  @default(false)
  lender               String?
  currency             String   @default("INR")
  // Original sanctioned amount; outstanding is the current balance (seeded to
  // principal at creation, reduced by payments).
  principalMinor       BigInt
  outstandingMinor     BigInt?
  annualInterestRatePct Float
  minimumPaymentMinor  BigInt
  // Scheduled installment for fixed-EMI loans (nullable; cards use the minimum).
  emiMinor             BigInt?
  status               DebtStatus @default(active)
  startedAt            DateTime?
  maturityAt           DateTime?
  dueDayOfMonth        Int?
  note                 String?
  createdAt            DateTime @default(now())
  updatedAt           DateTime @updatedAt
  createdById          String?
  updatedById          String?
  // Phase 2 advisory scoping — nullable, additive (M1b; householdId promoted to a
  // relation in M2-5). entityId supports entity-owned debts.
  firmId               String?
  householdId          String?
  entityId             String?
  household            Household? @relation(fields: [householdId], references: [id], onDelete: Cascade)
  entity               Entity?    @relation(fields: [entityId], references: [id], onDelete: SetNull)

  payments  DebtPayment[]

  @@index([userId])
  @@index([firmId])
  @@index([householdId])
  @@index([householdId, status])
  @@index([entityId])
}

// A repayment event against a debt (M2-5). The principal portion reduces the debt's
// outstanding balance; the interest portion is cost. Optionally links to the M2-4
// cashflow Transaction (reuse, not duplicate) via transactionId.
model DebtPayment {
  id             String          @id @default(cuid())
  debtId         String
  householdId    String
  firmId         String
  type           DebtPaymentType @default(emi)
  amountMinor    BigInt
  principalMinor BigInt          @default(0)
  interestMinor  BigInt          @default(0)
  currency       String          @default("INR")
  paidOn         DateTime
  transactionId  String?
  note           String?
  createdById    String?
  createdAt      DateTime        @default(now())

  debt Debt @relation(fields: [debtId], references: [id], onDelete: Cascade)

  @@index([debtId])
  @@index([householdId])
  @@index([firmId])
}

// Immutable point-in-time capture of a household's consolidated debt position, in the
// household base currency (M2-5). Mirrors NetWorthSnapshot (ADR-004) — create-only,
// never updated or deleted. `breakdown` freezes per-type/per-debt detail.
model DebtSnapshot {
  id                    String   @id @default(cuid())
  householdId           String
  firmId                String
  totalOutstandingMinor BigInt
  totalEmiMinor         BigInt
  weightedAvgRatePct    Float
  debtCount             Int
  breakdown             Json?
  currency              String   @default("INR")
  capturedAt            DateTime @default(now())

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@index([householdId])
  @@index([firmId])
  @@index([householdId, capturedAt])
}

model Goal {
  id                    String   @id @default(cuid())
  userId                String
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name                  String
  type                  GoalType
  currency              String   @default("INR")
  targetAmountMinor     BigInt
  currentAmountMinor    BigInt   @default(0)
  targetDate            DateTime
  expectedAnnualReturnPct Float  @default(10)
  createdAt             DateTime @default(now())
  updatedAt            DateTime @updatedAt
  // Phase 2 advisory scoping — nullable, additive; memberId links a goal to a
  // household member (M1b).
  firmId                String?
  householdId           String?
  memberId              String?

  @@index([userId])
  @@index([firmId])
  @@index([householdId])
  @@index([memberId])
}

model NetWorthSnapshot {
  id              String   @id @default(cuid())
  // Retail owner. Nullable — a snapshot is either retail (userId set) or advisory
  // (householdId set). Relaxing NOT NULL is backward-compatible.
  userId          String?
  user            User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  assetsMinor     BigInt
  liabilitiesMinor BigInt
  netWorthMinor   BigInt
  currency        String   @default("INR")
  capturedAt      DateTime @default(now())
  // Phase 2 advisory scoping (M1b; householdId promoted to a relation in M2-3).
  // Snapshots are immutable and stored in the household base currency at capture.
  firmId          String?
  householdId     String?
  household       Household? @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@index([userId, capturedAt])
  @@index([firmId])
  @@index([householdId])
  @@index([householdId, capturedAt])
}

model Recommendation {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  scoreKey   String
  priority   Int
  title      String
  rationale  String
  dismissed  Boolean  @default(false)
  createdAt  DateTime @default(now())
  // Phase 2 advisory scoping — nullable, additive; persists Top Actions per
  // household (M1b).
  firmId     String?
  householdId String?

  @@index([userId])
  @@index([firmId])
  @@index([householdId])
}

model Plan {
  id            String   @id @default(cuid())
  tier          PlanTier @unique
  name          String
  priceMinor    BigInt
  currency      String   @default("INR")
  interval      String   @default("month") // month | year
  features      Json
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  subscriptions Subscription[]
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId               String
  plan                 Plan               @relation(fields: [planId], references: [id])
  status               SubscriptionStatus @default(active)
  provider             String             @default("razorpay")
  providerSubscriptionId String?
  currentPeriodEnd     DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}

model FeatureOverride {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  feature   String
  enabled   Boolean
  createdAt DateTime @default(now())

  @@unique([userId, feature])
}

// Global feature flags / remote config managed from the admin panel.
model FeatureFlag {
  id          String   @id @default(cuid())
  key         String   @unique
  enabled     Boolean  @default(false)
  description String?
  // Optional JSON payload (e.g. rollout %, segment rules, config values)
  payload     Json?
  updatedAt   DateTime @updatedAt
}

model Consent {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  purpose   String // e.g. account_aggregation, marketing, data_processing
  granted   Boolean
  version   String   @default("1.0")
  createdAt DateTime @default(now())
  // Phase 2 advisory scoping — nullable, additive; consent at household scope (M1b).
  firmId    String?
  householdId String?

  @@index([userId, purpose])
  @@index([firmId])
  @@index([householdId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
}

model OtpCode {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel   String // phone | email
  target    String
  codeHash  String
  expiresAt DateTime
  consumedAt DateTime?
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([target])
}

// ---- Phase 2 tenancy tables (MOD-1 Firm & Tenancy, MOD-3 Household & Family) ----
// Additive only: these new tables carry their own firmId/householdId scope. Existing
// retail (userId-keyed) models are untouched in this migration. Every table below ships
// with an RLS lockdown (see the paired migration) so it is never exposed via PostgREST.

// A Firm is the tenant: a wealth-management practice that advisors belong to and
// households are owned by.
model Firm {
  id            String   @id @default(cuid())
  name          String
  brandName     String? // for report branding
  logoKey       String? // object-storage key
  baseCurrency  String   @default("INR")
  reviewCadence String   @default("quarterly")
  status        String   @default("active") // active | suspended | deleted
  planId        String? // firm-level plan (MOD-12; not yet wired)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  memberships Membership[]
  households  Household[]

  @@index([status])
}

// Join of a User to a Firm with a firm-scoped role. Authority inside a firm is
// resolved here, not from the global User.role.
model Membership {
  id        String   @id @default(cuid())
  firmId    String
  userId    String
  firmRole  FirmRole @default(SUPPORT)
  status    String   @default("active") // active | invited | disabled
  invitedAt DateTime @default(now())

  firm Firm @relation(fields: [firmId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([firmId, userId])
  @@index([userId])
}

// A Household groups everything for one family; it belongs to a firm and has an
// assigned advisor. Family name is encrypted at the service layer (CryptoService).
model Household {
  id           String   @id @default(cuid())
  firmId       String
  name         String // encrypted
  advisorId    String? // assigned advisor (User); plain column, no FK back-relation yet
  baseCurrency String   @default("INR")
  status       String   @default("active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  firm          Firm               @relation(fields: [firmId], references: [id], onDelete: Cascade)
  members       HouseholdMember[]
  entities      Entity[]
  accounts      Account[]
  netWorthSnaps NetWorthSnapshot[]
  transactions  Transaction[]
  budgets       Budget[]
  debts         Debt[]
  debtSnapshots DebtSnapshot[]

  @@index([firmId])
  @@index([advisorId])
}

// A person in a household. userId is set when the member has a portal login.
// name is encrypted at the service layer.
model HouseholdMember {
  id            String        @id @default(cuid())
  householdId   String
  userId        String? // set when the member has a portal login
  name          String // encrypted
  relation      String
  dateOfBirth   DateTime?
  isDependent   Boolean       @default(true)
  householdRole HouseholdRole @default(MEMBER)

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@index([householdId])
  @@index([userId])
}

// A legal entity (individual / HUF / trust / LLP / company) that owns accounts
// within a household. name and taxId are encrypted at the service layer.
model Entity {
  id          String     @id @default(cuid())
  householdId String
  firmId      String
  name        String // encrypted
  type        EntityType @default(individual)
  taxId       String? // encrypted
  createdAt   DateTime   @default(now())

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  accounts  Account[]
  debts     Debt[]

  @@index([householdId])
  @@index([firmId])
}

// Append-only audit trail. Never updated or deleted.
model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actor      User?    @relation("AuditActor", fields: [actorId], references: [id])
  actorRole  String?
  action     String
  entityType String?
  entityId   String?
  metadata   Json?
  ip         String?
  createdAt  DateTime @default(now())
  // Phase 2 advisory scoping — nullable, additive; tenant-scoped audit (M1b).
  firmId     String?

  @@index([actorId])
  @@index([action])
  @@index([createdAt])
  @@index([firmId])
}

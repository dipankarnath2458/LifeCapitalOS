{
  "name": "life-capital-os",
  "version": "0.1.0",
  "private": true,
  "description": "Life Capital OS — India's AI-powered Wealth Health & Family CFO platform (monorepo)",
  "packageManager": "pnpm@10.18.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:migrate": "pnpm --filter @lcos/api prisma:migrate",
    "db:seed": "pnpm --filter @lcos/api prisma:seed",
    "db:generate": "pnpm --filter @lcos/api prisma:generate",
    "infra:up": "docker compose -f infra/docker-compose.yml up -d",
    "infra:down": "docker compose -f infra/docker-compose.yml down"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.1.3",
    "typescript": "^5.6.2"
  }
}
